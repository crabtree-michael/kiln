exports[`Dashboard > matches the DOM-structure snapshot: settings view 1`] = `
<div>
  <div
    data-role="dashboard"
  >
    <div
      data-role="settings"
    >
      <section
        data-role="account-card"
      >
        <img
          alt=""
          data-role="account-avatar"
          src="https://example.com/a.png"
        />
        <div
          data-role="account-identity"
        >
          <div
            data-role="account-name"
          >
            Octocat
          </div>
          <div
            data-role="account-login"
          >
            @
            octocat
          </div>
        </div>
        <button
          type="button"
        >
          Sign out
        </button>
      </section>
      <form
        data-role="settings-form"
      >
        <label>
          Anthropic API key
          <span
            data-role="credential-input-row"
          >
            <input
              placeholder="configured · …x4Kd"
              type="password"
              value=""
            />
            <span
              data-name="anthropic_api_key"
              data-role="credential-status"
              data-status="skipped"
            />
          </span>
        </label>
        <span
          data-name="anthropic_api_key"
          data-role="secret-status"
          data-set="true"
        >
          configured · …x4Kd
        </span>
        <label>
          Amika API key
          <span
            data-role="credential-input-row"
          >
            <input
              placeholder=""
              type="password"
              value=""
            />
            <span
              data-name="amika_api_key"
              data-role="credential-status"
              data-status="skipped"
            />
          </span>
        </label>
        <span
          data-name="amika_api_key"
          data-role="secret-status"
          data-set="false"
        >
          not configured
        </span>
        <label>
          GitHub token
          <span
            data-role="credential-input-row"
          >
            <input
              placeholder="configured · …abcd"
              type="password"
              value=""
            />
            <span
              data-name="github_auth_token"
              data-role="credential-status"
              data-status="skipped"
            />
          </span>
        </label>
        <span
          data-name="github_auth_token"
          data-role="secret-status"
          data-set="true"
        >
          configured · …abcd
        </span>
        <label>
          Amika Claude credential ID
          <input
            type="text"
            value="cred-1"
          />
        </label>
      </form>
      <section
        data-role="notifications-field"
      >
        <div
          data-role="notifications-header"
        >
          <span
            data-role="notifications-title"
          >
            Notifications
          </span>
          <span
            data-role="notifications-status"
            data-status="unsupported"
          >
            Unavailable
          </span>
        </div>
        <p
          data-role="notifications-note"
        >
          This browser doesn’t support push notifications.
        </p>
      </section>
      <form
        data-role="project-form"
      >
        <label>
          Project name
          <input
            required=""
            type="text"
            value="kiln"
          />
        </label>
        <label>
          Repo URL
          <input
            required=""
            type="text"
            value="https://github.com/crabtree-michael/kiln"
          />
        </label>
        <label>
          Amika snapshot
          <input
            type="text"
            value="snap-1"
          />
        </label>
        <label>
          Brain model
          <input
            type="text"
            value="claude-sonnet"
          />
        </label>
        <label>
          Worker count
          <input
            type="number"
