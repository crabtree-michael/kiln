exports[`Dock snapshots > Retry with an un-committed transcript preserved (09 §5) 1`] = `
<div>
  <div
    data-dock-state="retry"
    data-role="dock"
  >
    <div
      data-dock-state="retry"
      data-role="dock-transcript"
    >
      <span
        data-ghost="true"
        data-role="dock-tail"
      >
        half a thought
      </span>
    </div>
    <div
      data-role="dock-controls"
    >
      <button
        aria-label="Talk"
        aria-pressed="false"
        data-dock-state="retry"
        data-role="dock-talk"
        type="button"
      >
        <span
          aria-hidden="true"
          data-role="dock-mic"
        >
          <span
            data-role="dock-mic-capsule"
          />
          <span
            data-role="dock-mic-arc"
          />
          <span
            data-role="dock-mic-stem"
          />
        </span>
        <span
          data-role="dock-label"
        >
          Tap to retry
        </span>
      </button>
      <button
        aria-label="Cancel"
        data-role="dock-cancel"
        type="button"
      >
        <span
          aria-hidden="true"
        >
          ×
        </span>
      </button>
    </div>
  </div>
</div>
`;
