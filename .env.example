# Copy to .env for local Docker Compose. Never commit the real .env (02 §12).
# Providers are real in v1 (02 §1); leave blank until a surface area needs them.

# Orchestrator brain — Anthropic Go SDK (02 §3, §6)
ANTHROPIC_API_KEY=

# Logging
KILN_LOG_LEVEL=info

# Observability — Sentry (spec 10 §6). Unset = SDKs no-op locally.
# Backend errors/traces/logs DSN (real secret):
SENTRY_BACKEND_DSN=
# Frontend (client) DSN — public, baked into the build as VITE_SENTRY_DSN, not a secret:
SENTRY_FRONTEND_DSN=
# Source-map upload token (org token, build-time only) + read-only user token for slug lookup:
# SENTRY_AUTH_TOKEN=
# SENTRY_PERSONAL_TOKEN=

# Voice pipeline (02 §9) — provider TBD in that section
# STT_API_KEY=
# TTS_API_KEY=

# Notification transport (02 §10) — transport TBD in that section
# PUSH_PROVIDER_KEY=

# Agent platform (02 §8) — Amika stays a mock until its real docs land (01 §11)
# AMIKA_API_KEY=
