              data-role="header-status-empty"
            >
              No active streams
            </div>
          </div>
        </div>
      </header>
      <div
        data-role="backlog"
      >
        <div
          data-role="backlog-slot"
        >
          <article
            data-kind="proposal"
            data-role="feed-card"
          >
            <div
              data-role="feed-card-head"
            >
              <span
                data-role="feed-card-label"
              >
                Login Redesign
              </span>
              <span
                data-role="feed-card-tag"
              >
                Proposal
              </span>
              <span
                data-role="feed-card-age"
              >
                1m
              </span>
            </div>
            <button
              aria-label="Open ticket: Login Redesign"
              data-role="feed-card-open"
              type="button"
            >
              <span
                data-role="feed-card-body"
              >
                Rework the login screen to a single-column layout with inline validation.
              </span>
              <span
                aria-hidden="true"
                data-role="feed-card-open-hint"
              >
                Read full ticket
              </span>
            </button>
            <div
              data-role="feed-card-actions"
            >
              <button
                data-role="proposal-accept"
                type="button"
              >
                Accept
              </button>
            </div>
          </article>
        </div>
      </div>
    </section>
    <div
      data-role="dock-region"
    >
      <div
        data-role="activity-row"
      />
      <div
        data-dock-state="listening"
        data-role="dock"
      >
        <div
          data-role="dock-controls"
        >
          <button
            aria-label="Talk"
            aria-pressed="true"
            data-dock-state="listening"
            data-role="dock-talk"
            type="button"
          >
            <span
              aria-hidden="true"
              data-role="dock-mic"
            >
              <span
                data-role="dock-mic-orb"
              />
              <span
                data-role="dock-mic-capsule"
              />
              <span
                data-role="dock-mic-arc"
              />
              <span
                data-role="dock-mic-stem"
              />
            </span>
            <span
              data-role="dock-label"
            >
              Listening…
            </span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
`;

