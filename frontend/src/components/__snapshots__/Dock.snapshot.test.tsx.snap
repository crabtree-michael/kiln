exports[`Dock snapshots > Retry with an un-committed transcript preserved (09 §5) 1`] = `
<div>
  <div
    data-dock-state="retry"
    data-role="dock"
  >
    <div
      data-dock-state="retry"
      data-role="dock-transcript"
    >
      <span
        data-ghost="true"
        data-role="dock-tail"
      >
        half a thought
      </span>
    </div>
    <div
      data-role="dock-controls"
    >
      <button
        aria-label="Talk"
        aria-pressed="false"
        data-dock-state="retry"
        data-role="dock-talk"
        type="button"
      >
        <span
          aria-hidden="true"
          data-role="dock-mic"
        >
          <span
            data-role="dock-mic-orb"
            style="--mic-level: 0;"
          />
          <span
            data-role="dock-mic-capsule"
          />
          <span
