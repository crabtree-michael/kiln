# Copy to .env for local Docker Compose. Never commit the real .env (02 §12).
# Providers are real in v1 (02 §1); leave blank until a surface area needs them.

# Orchestrator brain — Anthropic Go SDK (02 §3, §6)
ANTHROPIC_API_KEY=

# Logging
KILN_LOG_LEVEL=info

# Observability — Sentry (spec 10 §6). Unset = SDKs no-op locally.
# Backend errors/traces/logs DSN (real secret):
SENTRY_BACKEND_DSN=
# Frontend (client) DSN — public, baked into the build as VITE_SENTRY_DSN, not a secret:
SENTRY_FRONTEND_DSN=
# Source-map upload token (org token, build-time only) + read-only user token for slug lookup:
# SENTRY_AUTH_TOKEN=
# SENTRY_PERSONAL_TOKEN=

# Voice pipeline (02 §9) — provider TBD in that section
# STT_API_KEY=
# TTS_API_KEY=

# Web Push notifications (02 §10). Supply your own VAPID key pair — the app never
# generates it. Both keys empty ⇒ push is disabled (GET /api/push/key 404s and the
# runtime keeps the log-only notifier), so local dev works without them.
# Generate a pair with, e.g., `npx web-push generate-vapid-keys`.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# The VAPID "sub" claim: a mailto: or https contact the push service can reach.
VAPID_SUBJECT=mailto:you@example.com

# Agent platform (02 §8) — Amika stays a mock until its real docs land (01 §11)
# AMIKA_API_KEY=

# Multi-user phase 1 — dashboard auth (spec 11 §2, §7).
# OAuth app: github.com/settings/applications/new, callback
# http://localhost:5173/auth/github/callback for dev.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Comma-separated GitHub logins allowed to sign in (empty = nobody).
KILN_ALLOWED_GITHUB_USERS=
# 32-byte hex master key for per-user secrets: openssl rand -hex 32
KILN_SECRETS_KEY=
# Phase 2 (spec 11 §3): GitHub login the boot-time adoption seeds the owner
# user/project from and backfills every legacy orphan row (tickets, workers,
# events, …) into. Requires the three identity vars above to be set (identity
# mounted). Unset = no adoption; the NOT NULL finalizer still runs (a no-op on
# a fresh, empty DB).
KILN_BOOTSTRAP_GITHUB_USER=
