// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`PrimaryScreenView > matches the DOM-structure snapshot: all-clear (4d) 1`] = `
<div>
  <div
    data-connection-state="connected"
    data-role="primary-screen"
  >
    <section
      aria-label="Feed"
      data-connection-state="connected"
      data-role="feed"
      role="region"
    >
      <header
        data-role="feed-header"
      >
        <div
          data-role="kiln-mark"
        >
          <span
            aria-hidden="true"
            data-role="kiln-glyph"
          />
          <span
            data-role="kiln-wordmark"
          >
            Kiln
          </span>
        </div>
        <div
          data-role="header-status"
        >
          <button
            aria-controls="header-status-panel"
            aria-expanded="false"
            aria-haspopup="true"
            data-open="false"
            data-role="feed-status"
            type="button"
          >
            5 streams
            <span
              aria-hidden="true"
              data-role="feed-status-caret"
            />
          </button>
          <div
            aria-hidden="true"
            data-open="false"
            data-role="header-status-panel"
            id="header-status-panel"
          >
            <div
              data-role="header-status-heading"
            >
              Streams
            </div>
            <div
              data-role="header-status-empty"
            >
              No active streams
            </div>
          </div>
        </div>
      </header>
      <div
        data-role="backlog"
      >
        <div
          data-role="feed-empty"
        >
          <span
            aria-hidden="true"
            data-role="feed-empty-mark"
          />
          <span
            data-role="feed-empty-title"
          >
            Nothing needs you right now.
          </span>
          <div
            data-role="feed-empty-status"
          >
            <span
              aria-hidden="true"
              data-active="true"
              data-role="feed-empty-pulse"
            />
            <span>
              3 building · last word 6m ago
            </span>
          </div>
        </div>
      </div>
    </section>
    <div
      data-role="dock-region"
    >
      <div
        data-role="activity-row"
      />
      <div
        data-dock-state="listening"
        data-role="dock"
      >
        <div
          data-role="dock-controls"
        >
          <button
            aria-label="Talk"
            aria-pressed="true"
            data-dock-state="listening"
            data-role="dock-talk"
            type="button"
          >
            <span
              aria-hidden="true"
              data-role="dock-mic"
            >
              <span
                data-role="dock-mic-orb"
              />
              <span
                data-role="dock-mic-capsule"
              />
              <span
                data-role="dock-mic-arc"
              />
              <span
                data-role="dock-mic-stem"
              />
            </span>
            <span
              data-role="dock-label"
            >
              Listening…
            </span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
`;

exports[`PrimaryScreenView > matches the DOM-structure snapshot: blocker + while-you-were-away (4a) 1`] = `
<div>
  <div
    data-connection-state="connected"
    data-role="primary-screen"
  >
    <section
      aria-label="Feed"
      data-connection-state="connected"
      data-role="feed"
      role="region"
    >
      <header
        data-role="feed-header"
      >
        <div
          data-role="kiln-mark"
        >
          <span
            aria-hidden="true"
            data-role="kiln-glyph"
          />
          <span
            data-role="kiln-wordmark"
          >
            Kiln
          </span>
        </div>
        <div
          data-role="header-status"
        >
          <button
            aria-controls="header-status-panel"
            aria-expanded="false"
            aria-haspopup="true"
            data-open="false"
            data-role="feed-status"
            type="button"
          >
            1 blocker · 3 updates
            <span
              aria-hidden="true"
              data-role="feed-status-caret"
            />
          </button>
          <div
            aria-hidden="true"
            data-open="false"
            data-role="header-status-panel"
            id="header-status-panel"
          >
            <div
              data-role="header-status-heading"
            >
              Streams
            </div>
            <div
              data-role="header-status-empty"
            >
              No active streams
            </div>
          </div>
        </div>
      </header>
      <div
        data-role="backlog"
      >
        <div
          data-role="backlog-slot"
        >
          <article
            data-kind="blocker"
            data-role="feed-card"
          >
            <div
              data-role="feed-card-head"
            >
              <span
                aria-hidden="true"
                data-role="feed-card-dot"
              />
              <span
                data-role="feed-card-label"
              >
                Auth
              </span>
              <span
                data-role="feed-card-tag"
              >
                Blocker
              </span>
              <span
                data-role="feed-card-age"
              >
                now
              </span>
            </div>
            <p
              data-role="feed-card-body"
            >
              The /auth endpoint hands back both a session cookie and a JWT. Which should the client trust as the source of truth?
            </p>
          </article>
        </div>
        <div
          data-role="backlog-slot"
        >
          <div
            data-role="feed-divider"
          >
            While you were away
          </div>
          <article
            data-kind="update"
            data-role="feed-card"
          >
            <div
              data-role="feed-card-head"
            >
              <span
                data-role="feed-card-label"
              >
                Rate limiting
              </span>
              <span
                data-role="feed-card-tag"
              >
                Update
              </span>
              <span
                data-role="feed-card-age"
              >
                2m
              </span>
            </div>
            <p
              data-role="feed-card-body"
            >
              Added a fixed-window limiter on /auth — 20 requests a minute per IP. Suite is green.
            </p>
          </article>
        </div>
        <div
          data-role="backlog-slot"
        >
          <article
            data-kind="update"
            data-role="feed-card"
          >
            <div
              data-role="feed-card-head"
            >
              <span
                data-role="feed-card-label"
              >
                Email
              </span>
              <span
                data-role="feed-card-tag"
              >
                Update
              </span>
              <span
                data-role="feed-card-age"
              >
                14m
              </span>
            </div>
            <p
              data-role="feed-card-body"
            >
              Drafted three subject lines for the password-reset email and kept the clearest.
            </p>
          </article>
        </div>
        <div
          data-role="backlog-slot"
        >
          <article
            data-kind="update"
            data-role="feed-card"
          >
            <div
              data-role="feed-card-head"
            >
              <span
                data-role="feed-card-label"
              >
                Search
              </span>
              <span
                data-role="feed-card-tag"
              >
                Update
              </span>
              <span
                data-role="feed-card-age"
              >
                1h
              </span>
            </div>
            <p
              data-role="feed-card-body"
            >
              Reindexed the product catalog; queries are back under 40ms.
            </p>
          </article>
        </div>
      </div>
    </section>
    <div
      data-role="dock-region"
    >
      <div
        data-role="activity-row"
      />
      <div
        data-dock-state="listening"
        data-role="dock"
      >
        <div
          data-role="dock-controls"
        >
          <button
            aria-label="Talk"
            aria-pressed="true"
            data-dock-state="listening"
            data-role="dock-talk"
            type="button"
          >
            <span
              aria-hidden="true"
              data-role="dock-mic"
            >
              <span
                data-role="dock-mic-orb"
              />
              <span
                data-role="dock-mic-capsule"
              />
              <span
                data-role="dock-mic-arc"
              />
              <span
                data-role="dock-mic-stem"
              />
            </span>
            <span
              data-role="dock-label"
            >
              Listening…
            </span>
          </button>
        </div>
      </div>
    </div>
  </div>
</div>
`;

